# Compose variables for the official Docker/NAS deployment.
# Named volume (default):
OPENPHOTOS_DATA_MOUNT=openphotos-data:/data
# Bind mount example for NAS devices:
# OPENPHOTOS_DATA_MOUNT=/volume1/docker/openphotos:/data

OPENPHOTOS_IMAGE=ghcr.io/openphotos-ca/openphotos-arm64:latest
OPENPHOTOS_PORT=3003
TZ=UTC
LOG_LEVEL=info
OCR_ENABLED=false

# Set to true for NFS-backed or otherwise write-latency-sensitive storage.
RUSTUS_FORCE_FSYNC=false
