<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <fragment
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/app_nav_background"
        android:minHeight="@dimen/bottom_nav_min_height"
        app:itemActiveIndicatorStyle="@null"
        app:itemIconTint="@color/bottom_nav_item_tint"
        app:itemHorizontalTranslationEnabled="false"
        app:itemIconSize="@dimen/bottom_nav_icon_size"
        app:itemPaddingTop="@dimen/bottom_nav_item_padding_top"
        app:itemTextAppearanceActive="@style/Text.Appearance.OpenPhotos.BottomNav"
        app:itemTextAppearanceActiveBoldEnabled="false"
        app:itemTextAppearanceInactive="@style/Text.Appearance.OpenPhotos.BottomNav"
        app:itemTextColor="@color/bottom_nav_item_tint"
        app:labelVisibilityMode="labeled"
        app:paddingBottomSystemWindowInsets="false"
        app:menu="@menu/bottom_nav" />

</LinearLayout>
